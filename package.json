{
  "name": "mate-x",
  "productName": "MaTE X",
  "version": "0.1.2",
  "description": "The trust layer for AI-written code.",
  "main": ".vite/build/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/ferxalbs/mate-x.git"
  },
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "bun test src",
    "verify:package-config": "bun test forge.config.test.ts",
    "verify:legacy-terms": "bun run scripts/check-legacy-terms.ts",
    "verify": "bun run lint && bun run typecheck && bun run test:all && bun run verify:package-config && bun run verify:legacy-terms && bun run verify:bundle-purity",
    "smoke:live-rainy": "MATE_X_LIVE_RAINY=1 bun run scripts/live-rainy-smoke.ts",
    "test:packaged-self": "bun test qa/packaged/control-plane-recovery-driver.test.ts",
    "test:packaged-lifecycle": "bun run scripts/release/run-packaged-lifecycle.ts",
    "test:packaged-perf": "bun run scripts/release/run-packaged-perf-probe.ts",
    "test:packaged-e2e": "bun run scripts/release/run-packaged-e2e.ts",
    "test:fast": "bun test src/contracts src/lib src/electron/engineering --timeout 60000",
    "test:qa": "bun test qa",
    "test:all": "bun test src qa",
    "verify:bundle-purity": "bun run scripts/release/verify-bundle-purity.ts",
    "verify:release": "bun run verify && bun run package && bun run scripts/release/verify-bundle-purity.ts --require-asar && bun run scripts/release/run-packaged-e2e.ts",
    "tools:baseline": "bun run scripts/tooling-baseline.ts",
    "tools:baseline:electron": "bun run scripts/tooling-electron-baseline.ts",
    "tools:mission-fixtures": "bun run scripts/tooling-mission-fixtures.ts",
    "doctor": "npx react-doctor@latest"
  },
  "keywords": [],
  "author": {
    "name": "Enosis Labs, Inc.",
    "email": "legal@enosislabs.com"
  },
